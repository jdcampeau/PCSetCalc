def get_prime_form(numeric_prime_form):
    prime_form = []
    for pc in numeric_prime_form:
        if pc == 10:
            prime_form.append("T")
        elif pc == 11:
            prime_form.append("E")
        else:
            prime_form.append(pc)
    final_prime_form = ''.join(prime_form)
    return final_prime_form


